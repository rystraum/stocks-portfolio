<%= render "shared/header", text: "Crypto Activity Imports" do %>
  <%= link_to "Import from CoinsPH", new_crypto_activity_import_path, class: "btn btn-success" %>
<% end %>

<table class="table table-striped m-6">
  <thead class="thead-dark">
    <tr>
      <th>Date</th>
      <th>Filename</th>
      <th>Status</th>
      <th>Items</th>
      <th>Duplicates</th>
      <th>Created Activities</th>
      <th class="action-column">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @imports.each do |import| %>
      <tr>
        <td><%= import.created_at.strftime("%Y-%m-%d %H:%M") %></td>
        <td><%= import.filename %></td>
        <td><span class="badge <%= import.completed? ? 'badge-soft-success' : import.resolving? ? 'badge-soft-warning' : 'badge-soft-danger' %>"><%= import.status.titleize %></span></td>
        <td><%= import.import_items.count %></td>
        <td><%= import.import_items.where.not(duplicate_crypto_activity_id: nil).count %></td>
        <td><%= import.crypto_activities.count %></td>
        <td class="text-right">
          <%= link_to "View", crypto_activity_import_path(import), class: "btn btn-sm btn-primary" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
