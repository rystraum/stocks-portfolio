<%= render "shared/header", text: "Import Crypto Activities from CoinsPH" %>

<div class="max-w-xl mx-auto p-4">
  <div class="card">
    <div class="card-body">
      <%= form_with(url: crypto_activity_imports_path, local: true, multipart: true) do |f| %>
        <div class="form-group">
          <%= f.label :file, "CoinsPH CSV Export" %>
          <%= f.file_field :file, accept: ".csv", class: "form-control", required: true %>
          <small class="form-text text-muted">
            Upload a CSV export from CoinsPH containing columns: created_at, order_id, pair, order_type, side, executed_price, executed, total, fee
          </small>
        </div>
        <div class="form-group mt-4">
          <%= f.submit "Upload and Import", class: "btn btn-primary" %>
          <%= link_to "Back", crypto_activities_path, class: "btn btn-secondary ml-2" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
